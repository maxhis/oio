{
  "name": "oio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "cf:dev": "wrangler dev",
    "cf:deploy": "pnpm build && wrangler deploy",
    "cf:d1:migrate:local": "wrangler d1 migrations apply oio --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply oio --remote"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vue-tsc": "^2.0.6",
    "wrangler": "^4.0.0"
  }
}
